[Unit]
Description=Sentinel Security System v3.12
After=network.target

[Service]
Type=simple
User=sentinellite-tampere
WorkingDirectory=/home/sentinellite-tampere/sentinel
EnvironmentFile=/etc/sentinel.env
ExecStart=/usr/bin/python3 main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
